---
---
<canvas id="hero-canvas" aria-hidden="true"></canvas>

<style>
  #hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
  import * as THREE from "three";

  const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement;

  // Watch #main-content instead of polling — fires reliably when CLILoader reveals it.
  function onVisible(cb: () => void) {
    const main = document.getElementById("main-content");
    if (!main || main.style.display === "block") { setTimeout(cb, 50); return; }
    let done = false;
    const fire = () => { if (done) return; done = true; setTimeout(cb, 60); };
    const obs = new MutationObserver(() => {
      if (main.style.display === "block") { obs.disconnect(); fire(); }
    });
    obs.observe(main, { attributes: true, attributeFilter: ["style"] });
    setTimeout(() => { obs.disconnect(); fire(); }, 2700);
  }

  onVisible(() => {
    const W = canvas.offsetWidth  || canvas.clientWidth  || window.innerWidth;
    const H = canvas.offsetHeight || canvas.clientHeight || window.innerHeight;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
    renderer.setSize(W, H, false);
    renderer.setClearColor(0x000000, 0);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(60, W / H, 0.1, 100);
    camera.position.set(0, 0, 5.5);

    function resize() {
      const w = canvas.offsetWidth || window.innerWidth;
      const h = canvas.offsetHeight || window.innerHeight;
      if (!w || !h) return;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    new ResizeObserver(resize).observe(canvas);

    // ── Torus knot — dominant hero element ──────────────────────────────
    const knot = new THREE.Mesh(
      new THREE.TorusKnotGeometry(1.2, 0.38, 200, 20),
      new THREE.MeshBasicMaterial({ color: 0xdde3ec, wireframe: true, transparent: true, opacity: 0.72 })
    );
    scene.add(knot);

    // ── Solid knot underneath for glow illusion ──────────────────────────
    const knotSolid = new THREE.Mesh(
      new THREE.TorusKnotGeometry(1.2, 0.38, 200, 20),
      new THREE.MeshBasicMaterial({ color: 0x222836, transparent: true, opacity: 0.55 })
    );
    scene.add(knotSolid);

    // ── Icosahedra ────────────────────────────────────────────────────────
    const ico = new THREE.Mesh(
      new THREE.IcosahedronGeometry(0.85, 0),
      new THREE.MeshBasicMaterial({ color: 0xdde3ec, wireframe: true, transparent: true, opacity: 0.50 })
    );
    ico.position.set(3.6, -1.2, -2);
    scene.add(ico);

    const ico2 = new THREE.Mesh(
      new THREE.IcosahedronGeometry(0.5, 0),
      new THREE.MeshBasicMaterial({ color: 0xdde3ec, wireframe: true, transparent: true, opacity: 0.38 })
    );
    ico2.position.set(-3.8, 1.4, -1.5);
    scene.add(ico2);

    const ico3 = new THREE.Mesh(
      new THREE.IcosahedronGeometry(0.32, 0),
      new THREE.MeshBasicMaterial({ color: 0xdde3ec, wireframe: true, transparent: true, opacity: 0.28 })
    );
    ico3.position.set(2.6, 2.8, -3);
    scene.add(ico3);

    // ── Particles ────────────────────────────────────────────────────────
    const COUNT = 320;
    const pos = new Float32Array(COUNT * 3);
    for (let i = 0; i < COUNT; i++) {
      pos[i*3]   = (Math.random()-0.5)*22;
      pos[i*3+1] = (Math.random()-0.5)*16;
      pos[i*3+2] = (Math.random()-0.5)*8;
    }
    const ptGeo = new THREE.BufferGeometry();
    ptGeo.setAttribute("position", new THREE.BufferAttribute(pos, 3));
    const particles = new THREE.Points(ptGeo,
      new THREE.PointsMaterial({ size: 0.032, color: 0xe2e8f0, transparent: true, opacity: 0.65, sizeAttenuation: true })
    );
    scene.add(particles);

    // ── Mouse parallax ───────────────────────────────────────────────────
    const mouse = { x: 0, y: 0 };
    window.addEventListener("mousemove", (e) => {
      mouse.x = (e.clientX / window.innerWidth  - 0.5) * 2;
      mouse.y = (e.clientY / window.innerHeight - 0.5) * 2;
    });

    // ── Render loop ──────────────────────────────────────────────────────
    const clock = new THREE.Clock();
    (function animate() {
      requestAnimationFrame(animate);
      const d = clock.getDelta();

      knot.rotation.x += d * 0.22;
      knot.rotation.y += d * 0.16;
      knotSolid.rotation.x = knot.rotation.x;
      knotSolid.rotation.y = knot.rotation.y;
      knot.position.x += (mouse.x * 0.7  - knot.position.x) * 0.04;
      knot.position.y += (-mouse.y * 0.5  - knot.position.y) * 0.04;
      knotSolid.position.copy(knot.position);

      ico.rotation.x -= d * 0.11;
      ico.rotation.z += d * 0.09;
      ico.position.x += (-mouse.x * 1.5 - (ico.position.x - 3.6)) * 0.03;
      ico.position.y += (mouse.y  * 1.1 - (ico.position.y + 1.2)) * 0.03;

      ico2.rotation.y += d * 0.13;
      ico2.position.x += (mouse.x * 0.9 - (ico2.position.x + 3.8)) * 0.025;

      ico3.rotation.x += d * 0.10;
      ico3.rotation.z -= d * 0.08;

      particles.rotation.y += d * 0.014;

      renderer.render(scene, camera);
    })();
  });
</script>
