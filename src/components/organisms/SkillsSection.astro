---
const skills = [
  {
    name: "Inglés",
    detail: "B2 — documentación técnica y comunicación profesional",
  },
  {
    name: "Trabajo en equipo",
    detail: "Adaptación a distintos roles dentro de un equipo de desarrollo",
  },
  {
    name: "Organización",
    detail: "Gestión de tiempos y cumplimiento consistente de entregas",
  },
  {
    name: "Resolución de problemas",
    detail: "Análisis sistemático y búsqueda de soluciones efectivas",
  },
  {
    name: "Comunicación",
    detail: "Claridad técnica y habilidades de presentación y oratoria",
  },
  {
    name: "Aprendizaje autónomo",
    detail: "Exploración continua de nuevas tecnologías y metodologías",
  },
];
---

<section id="habilidades" class="reveal-section skills-section">
  <div class="skills-inner">

    <div class="skills-header">
      <p class="skills-label">Competencias</p>
      <h2 class="skills-heading">Habilidades blandas</h2>
    </div>

    <ul class="skills-list">
      {skills.map((skill, i) => (
        <li class="skills-item">
          <span class="skills-index">{String(i + 1).padStart(2, "0")}</span>
          <span class="skills-name">{skill.name}</span>
          <span class="skills-detail">{skill.detail}</span>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .skills-section {
    padding: 3rem 1.5rem;
    background: #080808;
  }

  .skills-inner {
    max-width: 56rem;
    margin: 0 auto;
  }

  /* ── Header ── */
  .skills-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #666;
    margin-bottom: 1rem;
  }

  .skills-heading {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    letter-spacing: -0.03em;
    color: #f0f0f0;
    margin-bottom: 2rem;
  }

  /* ── List ── */
  .skills-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .skills-item {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: border-color 0.2s ease;
  }

  .skills-item:first-child {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .skills-item:hover {
    border-bottom-color: rgba(226, 232, 240, 0.2);
  }

  .skills-index {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    color: #444;
    letter-spacing: 0.05em;
  }

  .skills-name {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: #f0f0f0;
    letter-spacing: -0.01em;
  }

  .skills-detail {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: #555;
    text-align: right;
    max-width: 24rem;
    line-height: 1.5;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .skills-item {
      grid-template-columns: 2rem 1fr;
      grid-template-rows: auto auto;
    }

    .skills-detail {
      grid-column: 2;
      text-align: left;
      color: #555;
    }
  }
</style>
