---
const { id = "", className = "" } = Astro.props;
---

<section
  id={id}
  class={`reveal-section section-base ${className}`}
>
  <div class="section-inner">
    <slot />
  </div>
</section>

<style>
  .section-base {
    background: #080808;
    padding: 3rem 1.5rem;
    color: #f0f0f0;
  }

  .section-inner {
    max-width: 64rem;
    margin: 0 auto;
  }
</style>
