---
import "../styles/global.css";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>César Enríquez | Portafolio</title>
    <link rel="icon" type="image/x-icon" href="/Portfolio/icons/favicon.ico" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-bg text-text-base font-body">
    <!-- Custom cursor -->
    <div id="cursor" aria-hidden="true"></div>
    <div id="cursor-dot" aria-hidden="true"></div>

    <slot />

    <a
      href="https://cesars39.github.io/Portfolio/"
      class="fixed bottom-6 right-6 z-50 bg-white/10 backdrop-blur-md text-white p-3 rounded-full shadow-lg transition-all duration-300 group border border-white/20 hover:bg-white/20"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6 group-hover:scale-110 transition"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3 12l9-9 9 9M4 10v10h5v-6h6v6h5V10"></path>
      </svg>
    </a>

    <script>
      import "../scripts/animations.js";
    </script>

    <script is:inline>
      const homeButton = document.querySelector(
        'a[href="https://cesars39.github.io/Portfolio/"]'
      );
      homeButton.addEventListener("click", (e) => {
        if (window.location.href === "https://cesars39.github.io/Portfolio/") {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: "smooth" });
        } else {
          sessionStorage.setItem("fromHomeButton", "true");
        }
      });

      // Custom cursor
      const cursor = document.getElementById("cursor");
      const cursorDot = document.getElementById("cursor-dot");

      let mouseX = -100, mouseY = -100;
      let cursorX = -100, cursorY = -100;

      document.addEventListener("mousemove", (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        cursorDot.style.transform = `translate(${mouseX - 4}px, ${mouseY - 4}px)`;
      });

      function animateCursor() {
        cursorX += (mouseX - cursorX) * 0.12;
        cursorY += (mouseY - cursorY) * 0.12;
        cursor.style.transform = `translate(${cursorX - 20}px, ${cursorY - 20}px)`;
        requestAnimationFrame(animateCursor);
      }
      animateCursor();

      // Hover state on interactive elements
      const interactiveEls = document.querySelectorAll("a, button, [role='button']");
      interactiveEls.forEach((el) => {
        el.addEventListener("mouseenter", () => cursor.classList.add("cursor--hover"));
        el.addEventListener("mouseleave", () => cursor.classList.remove("cursor--hover"));
      });
    </script>

    <style>
      /* ── Design tokens ── */
      :root {
        --bg: #080808;
        --surface: #0f0f0f;
        --border: rgba(255, 255, 255, 0.08);
        --text: #f0f0f0;
        --text-muted: #666;
        --accent: #e2e8f0;
        --accent-glow: rgba(226, 232, 240, 0.15);
      }

      /* ── Base ── */
      html,
      body {
        background-color: var(--bg);
        color: var(--text);
        font-family: 'Inter', sans-serif;
        overflow-x: hidden;
        max-width: 100vw;
        cursor: none;
      }

      * {
        box-sizing: border-box;
      }

      /* ── Custom cursor ── */
      #cursor {
        position: fixed;
        top: 0;
        left: 0;
        width: 40px;
        height: 40px;
        border: 1px solid var(--accent);
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        transition: width 0.2s ease, height 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
        will-change: transform;
      }

      #cursor-dot {
        position: fixed;
        top: 0;
        left: 0;
        width: 8px;
        height: 8px;
        background-color: var(--accent);
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        will-change: transform;
      }

      #cursor.cursor--hover {
        width: 56px;
        height: 56px;
        border-color: var(--accent);
        background-color: var(--accent-glow);
      }

      /* ── Typography ── */
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Syne', sans-serif;
      }

      /* ── Layout helpers ── */
      .container,
      .max-w-4xl,
      .max-w-5xl,
      .max-w-6xl,
      .max-w-7xl {
        width: 100%;
        max-width: calc(100vw - 2rem);
        margin-left: auto;
        margin-right: auto;
      }

      /* ── Mobile ── */
      @media (max-width: 768px) {
        body { cursor: auto; }
        #cursor, #cursor-dot { display: none; }

        .gradient-text {
          font-size: clamp(2.5rem, 12vw, 6rem) !important;
          line-height: 0.9;
          word-spacing: -0.1em;
          letter-spacing: -0.02em;
        }

        section {
          padding-left: 1rem;
          padding-right: 1rem;
        }

        .grid {
          grid-template-columns: 1fr;
        }

        h1, h2, h3 {
          text-align: center;
          word-wrap: break-word;
          hyphens: auto;
        }

        [id*="parallax"] {
          transform: none !important;
        }
      }

      @media (max-width: 375px) {
        .gradient-text {
          font-size: clamp(2rem, 10vw, 4rem) !important;
          line-height: 0.85;
        }

        section {
          padding-left: 0.75rem;
          padding-right: 0.75rem;
        }
      }
    </style>
  </body>
</html>
