---
const {
  title,
  description,
  image,
  link,
  repo,
  techStack = [],
  featured = false,
  demo,
} = Astro.props;
---

<article class="project-card">
  <a
    href={link ?? repo ?? "#"}
    class="project-card-link"
    target={link ? "_self" : "_blank"}
    rel={link ? "" : "noopener noreferrer"}
  >
    <!-- Full-bleed image -->
    <img loading="lazy" src={image} alt={title} class="project-img" />

    <!-- Always-on scrim so tags & title bar are legible -->
    <div class="project-scrim" aria-hidden="true"></div>

    <!-- Tech tags — top-left, always visible -->
    {techStack.length > 0 && (
      <div class="project-tags">
        {techStack.slice(0, 3).map((t: string) => (
          <span class="project-tag">{t}</span>
        ))}
      </div>
    )}

    <!-- Title bar — always visible at bottom -->
    <div class="project-title-bar">
      <span class="project-title-static">{title}</span>
    </div>

    <!-- Hover panel — slides up over the image -->
    <div class="project-panel">
      <h3 class="project-panel-title">{title}</h3>
      <p class="project-panel-desc">{description}</p>
      <div class="project-panel-footer">
        <span class="project-cta">Ver proyecto →</span>
        <div class="project-links">
          {repo && typeof repo === "string" && (
            <a
              href={repo}
              target="_blank"
              rel="noopener noreferrer"
              class="project-link"
              onclick="event.stopPropagation()"
            >GitHub</a>
          )}
          {demo && (
            <a
              href={demo}
              target="_blank"
              rel="noopener noreferrer"
              class="project-link"
              onclick="event.stopPropagation()"
            >Demo</a>
          )}
        </div>
      </div>
    </div>
  </a>
</article>

<style>
  /* ── Card shell ── */
  .project-card {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: #0d0d0d;
    transition: border-color 0.35s ease;
  }

  .project-card:hover {
    border-color: rgba(255, 255, 255, 0.18);
  }

  .project-card-link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  /* ── Image ── */
  .project-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.75;
    transition: opacity 0.5s ease, transform 0.6s ease;
    will-change: transform, opacity;
  }

  .project-card:hover .project-img {
    opacity: 0.35;
    transform: translateY(-4px);
  }

  /* ── Base scrim ── */
  .project-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(8, 8, 8, 0.72) 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  /* ── Tags ── */
  .project-tags {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    z-index: 3;
  }

  .project-tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.57rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: rgba(226, 232, 240, 0.55);
    background: rgba(8, 8, 8, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.15rem 0.55rem;
    backdrop-filter: blur(6px);
  }

  /* ── Static title bar (always visible) ── */
  .project-title-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.9rem 1.1rem;
    z-index: 2;
    transition: opacity 0.25s ease;
  }

  .project-card:hover .project-title-bar {
    opacity: 0;
    pointer-events: none;
  }

  .project-title-static {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #e2e8f0;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  /* ── Hover panel ── */
  .project-panel {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(8, 8, 8, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 1.25rem 1.25rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    z-index: 4;
    transform: translateY(100%);
    transition: transform 0.38s cubic-bezier(0.33, 1, 0.68, 1);
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .project-card:hover .project-panel {
    transform: translateY(0);
  }

  .project-panel-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    color: #f0f0f0;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin: 0;
  }

  .project-panel-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    color: #888;
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  /* ── Panel footer ── */
  .project-panel-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.6rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .project-cta {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #e2e8f0;
    transition: opacity 0.2s ease;
  }

  .project-card:hover .project-cta {
    opacity: 0.85;
  }

  .project-links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .project-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #555;
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    z-index: 5;
  }

  .project-link:hover {
    color: #e2e8f0;
  }

  /* ── Mobile: keep simpler (no hover on touch) ── */
  @media (max-width: 560px) {
    .project-card {
      aspect-ratio: 4 / 3;
    }

    .project-panel {
      transform: translateY(0);
    }

    .project-title-bar {
      display: none;
    }

    .project-card:hover .project-img {
      opacity: 0.75;
      transform: none;
    }
  }
</style>
