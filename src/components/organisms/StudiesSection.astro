---
interface Study {
  image: string;
  alt: string;
  title: string;
  subtitle: string;
  date: string;
  extra?: string;
  status?: "completed" | "current" | "planned";
  skills?: string[];
  glow?: string;
}

const { studies } = Astro.props as { studies: Study[] };

const statusLabel = {
  completed: "Completado",
  current: "En curso",
  planned: "Planeado",
};
---

<section id="estudios" class="reveal-section timeline-section">
  <div class="timeline-inner">

    <div class="timeline-header">
      <p class="timeline-label">Formación</p>
      <h2 class="timeline-heading">Educación</h2>
    </div>

    <div class="timeline">
      <!-- vertical line -->
      <div class="timeline-line" aria-hidden="true"></div>

      {studies.map((study) => {
        const status = study.status ?? "completed";
        return (
          <div class="timeline-item">
            <div class="timeline-dot" aria-hidden="true"></div>

            <div class="timeline-meta">
              <span class="timeline-date">{study.date}</span>
              {study.extra && <span class="timeline-extra">{study.extra}</span>}
              <span class="timeline-status">{statusLabel[status]}</span>
            </div>

            <div class="timeline-body">
              <h3 class="timeline-title">{study.title}</h3>
              <p class="timeline-subtitle">{study.subtitle}</p>

              {study.skills && study.skills.length > 0 && (
                <ul class="timeline-skills">
                  {study.skills.map((s) => (
                    <li class="timeline-skill-tag">{s}</li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>

<style>
  .timeline-section {
    padding: 3rem 1.5rem;
    background: #080808;
  }

  .timeline-inner {
    max-width: 48rem;
    margin: 0 auto;
  }

  /* ── Header ── */
  .timeline-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #666;
    margin-bottom: 1rem;
  }

  .timeline-heading {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    letter-spacing: -0.03em;
    color: #f0f0f0;
    margin-bottom: 2rem;
  }

  /* ── Timeline shell ── */
  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline-line {
    position: absolute;
    left: 0;
    top: 0.45rem;
    bottom: 0;
    width: 1px;
    background: rgba(255, 255, 255, 0.08);
  }

  /* ── Single item ── */
  .timeline-item {
    position: relative;
    padding-bottom: 3rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -2.3rem;
    top: 0.45rem;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #e2e8f0;
    opacity: 0.5;
  }

  /* ── Meta row (date / status) ── */
  .timeline-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }

  .timeline-date {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    color: #555;
    letter-spacing: 0.04em;
  }

  .timeline-extra {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    color: #444;
  }

  .timeline-status {
    font-family: 'Inter', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #e2e8f0;
    opacity: 0.45;
    margin-left: auto;
  }

  /* ── Body ── */
  .timeline-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: #f0f0f0;
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
  }

  .timeline-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: #555;
    margin-bottom: 0.85rem;
  }

  /* ── Skill tags ── */
  .timeline-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-skill-tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: #666;
    border: 1px solid rgba(255, 255, 255, 0.07);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
  }
</style>
