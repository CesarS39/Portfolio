---
import ProjectCard from "../molecules/ProjectCard.astro";

interface Project {
  title: string;
  description: string;
  image: string;
  repo?: string | boolean;
  demo?: string;
  link?: string;
  techStack?: string[];
  featured?: boolean;
}

const { projects } = Astro.props as { projects: Project[] };
---

<section id="projects" class="pjs">

  <!-- Constellation background (Three.js) -->
  <canvas id="pjs-canvas" aria-hidden="true"></canvas>

  <!-- Radial spotlight behind center -->
  <div class="pjs-spotlight" aria-hidden="true"></div>

  <!-- Header -->
  <div class="pjs-header">
    <p class="pjs-label">Trabajo</p>
    <h2 class="pjs-heading">Proyectos</h2>
  </div>

  <!--
    Track wrapper:
    - position:relative so arrows are positioned relative to it
    - pseudo ::before/::after handle edge vignette at higher local z
    - arrows inside here at z:10 (above vignette ::before/after at z:5)
  -->
  <div class="pjs-wrap" id="pjs-wrap">

    <div class="pjs-track" id="pjs-track">
      {projects.map((project, i) => (
        <div class="pjs-slide" data-idx={i}>
          <ProjectCard
            title={project.title}
            description={project.description}
            image={project.image}
            repo={project.repo && project.repo !== false ? String(project.repo) : undefined}
            demo={project.demo}
            link={project.link}
            techStack={project.techStack}
            featured={project.featured}
          />
        </div>
      ))}
    </div>

    <!-- Arrows inside wrap — z:10 beats the ::before/::after vignette at z:5 -->
    <button class="pjs-arrow pjs-arrow--l" id="pjs-prev" aria-label="Anterior">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M11 4L6 9L11 14" stroke="currentColor" stroke-width="1.5"
              stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <button class="pjs-arrow pjs-arrow--r" id="pjs-next" aria-label="Siguiente">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M7 4L12 9L7 14" stroke="currentColor" stroke-width="1.5"
              stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

  </div>

  <!-- Dots + counter -->
  <div class="pjs-nav">
    <div class="pjs-dots" id="pjs-dots">
      {projects.map((_, i) => (
        <button class="pjs-dot" data-dot={i} aria-label={`Proyecto ${i + 1}`}></button>
      ))}
    </div>
    <span class="pjs-counter" id="pjs-counter">1 / {projects.length}</span>
  </div>

</section>

<style>
  /* ── Shell ── */
  .pjs {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    background: #080808;
    overflow: hidden;
    padding: 5rem 0 4rem;
  }

  /* ── Background canvas ── */
  #pjs-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    z-index: 0;
    pointer-events: none;
  }

  /* ── Radial spotlight in center ── */
  .pjs-spotlight {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 680px;
    height: 400px;
    background: radial-gradient(
      ellipse,
      rgba(226, 232, 240, 0.06) 0%,
      rgba(226, 232, 240, 0.018) 45%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 1;
  }

  /* ── Header ── */
  .pjs-header {
    position: relative;
    z-index: 5;
    text-align: center;
  }
  .pjs-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #3a3a3a;
    margin-bottom: 0.75rem;
  }
  .pjs-heading {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 2.8rem);
    letter-spacing: -0.04em;
    color: #f0f0f0;
    margin: 0;
  }

  /* ── Carousel wrapper ── */
  .pjs-wrap {
    position: relative;
    width: 100%;
    z-index: 5;
    /* height determined by content */
  }

  /*
    Edge vignette via pseudo-elements:
    z:5 within .pjs-wrap → above slides (z:auto), below arrows (z:10)
    pointer-events:none → clicks pass through to slides
  */
  .pjs-wrap::before,
  .pjs-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: clamp(80px, 18vw, 240px);
    pointer-events: none;
    z-index: 5;
  }
  .pjs-wrap::before {
    left: 0;
    background: linear-gradient(to right, rgba(8,8,8,0.97) 0%, transparent 100%);
  }
  .pjs-wrap::after {
    right: 0;
    background: linear-gradient(to left, rgba(8,8,8,0.97) 0%, transparent 100%);
  }

  /* ── Flex track — JS sets translateX ── */
  .pjs-track {
    display: flex;
    gap: 20px;
    /* No overflow:hidden — parent section clips via its own overflow */
    transition: transform 0.55s cubic-bezier(0.33, 1, 0.68, 1);
    will-change: transform;
  }

  /* ── Individual slide ── */
  .pjs-slide {
    flex: 0 0 400px;
    transition:
      transform 0.5s cubic-bezier(0.33, 1, 0.68, 1),
      filter    0.45s ease,
      opacity   0.4s ease;
    will-change: transform, filter;
  }

  /* ── Arrow buttons — z:10 inside wrap, above vignette (z:5) ── */
  .pjs-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(8, 8, 8, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #666;
    cursor: pointer;
    backdrop-filter: blur(10px);
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .pjs-arrow:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.25);
    color: #e2e8f0;
  }
  .pjs-arrow--l { left: 1.25rem; }
  .pjs-arrow--r { right: 1.25rem; }

  /* ── Bottom nav ── */
  .pjs-nav {
    position: relative;
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }
  .pjs-dots {
    display: flex;
    gap: 0.55rem;
    align-items: center;
  }
  .pjs-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(255,255,255,0.18);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s, transform 0.3s;
  }
  .pjs-dot.active {
    background: #e2e8f0;
    transform: scale(1.6);
  }
  .pjs-counter {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: #333;
    font-variant-numeric: tabular-nums;
  }

  /* ── Responsive slide width ── */
  @media (max-width: 900px)  { .pjs-slide { flex: 0 0 320px; } }
  @media (max-width: 600px)  { .pjs-slide { flex: 0 0 260px; } }
  @media (max-width: 400px)  { .pjs-slide { flex: 0 0 220px; } }
</style>

<script>
  /* ============================================================
     CAROUSEL — reads dimensions from DOM, no CSS var parsing
  ============================================================ */
  (function () {
    var track   = document.getElementById("pjs-track");
    var wrap    = document.getElementById("pjs-wrap");
    var dotWrap = document.getElementById("pjs-dots");
    var counter = document.getElementById("pjs-counter");
    var prevBtn = document.getElementById("pjs-prev");
    var nextBtn = document.getElementById("pjs-next");
    var section = document.getElementById("projects");

    if (!track || !wrap || !dotWrap) return;

    var slides = Array.prototype.slice.call(track.querySelectorAll(".pjs-slide"));
    var dots   = Array.prototype.slice.call(dotWrap.querySelectorAll(".pjs-dot"));
    var N      = slides.length;
    var cur    = 0;
    var autoId = null;
    var reId   = null;

    /* Read slide width and gap from the actual layout */
    function measure() {
      var cw  = slides[0] ? slides[0].offsetWidth : 400;
      var gap = 20;
      if (slides.length >= 2) {
        /* offsetLeft gives position BEFORE transforms, inside the flex container */
        var raw = slides[1].offsetLeft - slides[0].offsetLeft - cw;
        if (!isNaN(raw) && raw >= 0) gap = raw;
      }
      return { cw: cw, gap: gap };
    }

    function render() {
      var m     = measure();
      var cw    = m.cw;
      var gap   = m.gap;
      var wrapW = wrap.offsetWidth;

      /* Center the active slide in the wrapper */
      var offset = Math.round(wrapW / 2 - cw / 2 - cur * (cw + gap));
      track.style.transform = "translateX(" + offset + "px)";

      slides.forEach(function (el, i) {
        var dist = i - cur;
        var abs  = Math.abs(dist);

        /* Hide slides beyond ±3 positions */
        if (abs > 3) {
          el.style.opacity       = "0";
          el.style.filter        = "brightness(0)";
          el.style.transform     = "";
          el.style.pointerEvents = "none";
          return;
        }

        /*
          rotateY faces each card toward center:
            left cards  (dist < 0) → positive rotateY  (right face forward)
            right cards (dist > 0) → negative rotateY  (left face forward)
          perspective() is applied per-slide so tilt looks consistent
          regardless of the slide's horizontal position.
        */
        var rotY   = -dist * 14;
        var scale  = [1, 0.92, 0.83, 0.74][abs];
        var brite  = [1, 0.55, 0.26, 0.1 ][abs];
        var op     = abs > 2 ? 0.3 : 1;

        el.style.transform     = "perspective(900px) rotateY(" + rotY + "deg) scale(" + scale + ")";
        el.style.filter        = "brightness(" + brite + ")";
        el.style.opacity       = String(op);
        el.style.pointerEvents = abs === 0 ? "all" : "none";
      });

      /* Dots */
      dots.forEach(function (d, i) {
        d.classList.toggle("active", i === cur);
      });

      /* Counter */
      if (counter) counter.textContent = (cur + 1) + " / " + N;
    }

    function goTo(idx) {
      cur = ((idx % N) + N) % N;
      render();
    }
    function goNext() { goTo(cur + 1); }
    function goPrev() { goTo(cur - 1); }

    function startAuto() {
      clearInterval(autoId);
      autoId = setInterval(goNext, 4500);
    }
    function stopAuto()  { clearInterval(autoId); }
    function restartAuto() {
      clearTimeout(reId);
      reId = setTimeout(startAuto, 3800);
    }

    if (prevBtn) prevBtn.addEventListener("click", function () { stopAuto(); goPrev(); restartAuto(); });
    if (nextBtn) nextBtn.addEventListener("click", function () { stopAuto(); goNext(); restartAuto(); });

    dots.forEach(function (dot, i) {
      dot.addEventListener("click", function () { stopAuto(); goTo(i); restartAuto(); });
    });

    /* Touch swipe — only registers if horizontal motion dominates */
    var tx0 = 0, ty0 = 0;
    track.addEventListener("touchstart", function (e) {
      tx0 = e.touches[0].clientX;
      ty0 = e.touches[0].clientY;
    }, { passive: true });
    track.addEventListener("touchend", function (e) {
      var dx = tx0 - e.changedTouches[0].clientX;
      var dy = ty0 - e.changedTouches[0].clientY;
      if (Math.abs(dx) > Math.abs(dy) * 1.5 && Math.abs(dx) > 44) {
        stopAuto();
        dx > 0 ? goNext() : goPrev();
        restartAuto();
      }
    }, { passive: true });

    /* Pause when section scrolled away */
    new IntersectionObserver(function (entries) {
      entries[0].isIntersecting ? startAuto() : stopAuto();
    }, { threshold: 0.2 }).observe(section);

    /* Rerender on resize (card width changes at breakpoints) */
    new ResizeObserver(function () { render(); }).observe(wrap);

    /* Boot */
    render();
    startAuto();
  })();

  /* ============================================================
     CONSTELLATION — isolated so a Three.js error won't kill the carousel
  ============================================================ */
  (function () {
    var canvas  = document.getElementById("pjs-canvas");
    var section = document.getElementById("projects");
    if (!canvas || !section) return;

    var booted = false;

    new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting && !booted) {
        booted = true;
        import("three").then(function (mod) {
          var THREE = mod;
          boot(THREE);
        }).catch(function () { /* silently skip if three.js unavailable */ });
      }
    }, { threshold: 0.05 }).observe(section);

    function boot(THREE) {
      var W = canvas.offsetWidth  || window.innerWidth;
      var H = canvas.offsetHeight || window.innerHeight;

      var renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: false });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.4));
      renderer.setSize(W, H, false);
      renderer.setClearColor(0x000000, 0);

      var scene  = new THREE.Scene();
      var camera = new THREE.PerspectiveCamera(62, W / H, 0.1, 100);
      camera.position.set(0, 0, 6.5);

      new ResizeObserver(function () {
        var w = canvas.offsetWidth || window.innerWidth;
        var h = canvas.offsetHeight || window.innerHeight;
        renderer.setSize(w, h, false);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      }).observe(canvas);

      /* Particles */
      var COUNT = 130;
      var pPos  = new Float32Array(COUNT * 3);
      var vel   = [];
      for (var i = 0; i < COUNT; i++) {
        pPos[i*3]   = (Math.random() - 0.5) * 26;
        pPos[i*3+1] = (Math.random() - 0.5) * 17;
        pPos[i*3+2] = (Math.random() - 0.5) * 3;
        vel.push({ x: (Math.random() - 0.5) * 0.004, y: (Math.random() - 0.5) * 0.003 });
      }
      var ptGeo = new THREE.BufferGeometry();
      ptGeo.setAttribute("position", new THREE.BufferAttribute(pPos, 3));
      scene.add(new THREE.Points(ptGeo, new THREE.PointsMaterial({
        size: 0.05, color: 0xe2e8f0, transparent: true, opacity: 0.48, sizeAttenuation: true,
      })));

      /* Constellation lines */
      var MAX_SEG = 280;
      var lPos    = new Float32Array(MAX_SEG * 6);
      var lGeo    = new THREE.BufferGeometry();
      lGeo.setAttribute("position", new THREE.BufferAttribute(lPos, 3));
      lGeo.setDrawRange(0, 0);
      scene.add(new THREE.LineSegments(lGeo, new THREE.LineBasicMaterial({
        color: 0xe2e8f0, transparent: true, opacity: 0.09,
      })));

      var LINK2 = 4.0 * 4.0;
      function rebuildLines() {
        var p = ptGeo.attributes.position.array;
        var n = 0;
        for (var a = 0; a < COUNT && n < MAX_SEG; a++) {
          for (var b = a + 1; b < COUNT && n < MAX_SEG; b++) {
            var dx = p[a*3]-p[b*3], dy = p[a*3+1]-p[b*3+1], dz = p[a*3+2]-p[b*3+2];
            if (dx*dx + dy*dy + dz*dz < LINK2) {
              var base = n * 6;
              lPos[base]=p[a*3]; lPos[base+1]=p[a*3+1]; lPos[base+2]=p[a*3+2];
              lPos[base+3]=p[b*3]; lPos[base+4]=p[b*3+1]; lPos[base+5]=p[b*3+2];
              n++;
            }
          }
        }
        lGeo.attributes.position.needsUpdate = true;
        lGeo.setDrawRange(0, n * 2);
      }

      /* Background wireframe accents */
      function mkWire(geo, pos, op) {
        var m = new THREE.Mesh(geo, new THREE.MeshBasicMaterial({
          color: 0xdde3ec, wireframe: true, transparent: true, opacity: op,
        }));
        m.position.set(pos[0], pos[1], pos[2]);
        scene.add(m);
        return m;
      }
      var w1 = mkWire(new THREE.IcosahedronGeometry(1.5, 0), [5,  -1.5, -4], 0.05);
      var w2 = mkWire(new THREE.OctahedronGeometry(1.0,  0), [-5,  2,   -3], 0.04);
      var w3 = mkWire(new THREE.IcosahedronGeometry(0.6, 0), [2.5, 3.5, -2], 0.035);

      /* Render loop */
      var frame = 0;
      (function animate() {
        requestAnimationFrame(animate);
        var p = ptGeo.attributes.position.array;
        for (var i = 0; i < COUNT; i++) {
          p[i*3]   += vel[i].x;
          p[i*3+1] += vel[i].y;
          if (p[i*3]   >  13) p[i*3]   = -13;
          if (p[i*3]   < -13) p[i*3]   =  13;
          if (p[i*3+1] >   8.5) p[i*3+1] = -8.5;
          if (p[i*3+1] <  -8.5) p[i*3+1] =  8.5;
        }
        ptGeo.attributes.position.needsUpdate = true;
        if (frame % 2 === 0) rebuildLines();
        w1.rotation.x += 0.0007; w1.rotation.y += 0.001;
        w2.rotation.y -= 0.0008; w2.rotation.z += 0.0006;
        w3.rotation.x += 0.0009; w3.rotation.z -= 0.0007;
        renderer.render(scene, camera);
        frame++;
      })();
    }
  })();
</script>
