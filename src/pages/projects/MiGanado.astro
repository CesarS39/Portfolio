---
import Layout from "../../layouts/Layout.astro";
import HeroTitle from "../../components/atoms/HeroTitle.astro";
import BaseSection from "../../components/atoms/BaseSection.astro";
import TechnologyButton from "../../components/molecules/TechnologyButton.astro";
import FeatureCard from "../../components/molecules/FeatureCard.astro";
import ProjectCTA from "../../components/molecules/ProjectCTA.astro";

const techStack = [
  { name: "Regresión Lineal Simple" },
  { name: "JavaScript", icon: "devicon-javascript-plain" },
  { name: "TailwindCSS", icon: "devicon-tailwindcss-original" },
  { name: "Datos SNIIM" },
];

const features = [
  {
    title: "Modelo estadístico robusto",
    description: "Regresión lineal con R² = 0.939, entrenada con 1,119 registros del SNIIM de enero-julio 2025.",
  },
  {
    title: "Acceso universal gratuito",
    description: "Herramienta gratuita y accesible desde cualquier dispositivo, sin registro requerido.",
  },
  {
    title: "Cálculo instantáneo",
    description: "Estimación del precio total del ganado en tiempo real a partir del peso ingresado.",
  },
  {
    title: "Transparencia total",
    description: "Código abierto con metodología explicable: se muestra exactamente cómo se calculan los precios.",
  },
];

const regressionDetails = [
  {
    concept: "Ecuación del modelo",
    formula: "Precio = 102.53 × Peso_canal + 3,774.92",
    explanation: "Por cada kilogramo adicional, el precio aumenta $102.53 MXN.",
  },
  {
    concept: "Coeficiente de determinación",
    formula: "R² = 0.939",
    explanation: "El modelo explica el 93.9% de la variabilidad en los precios.",
  },
  {
    concept: "Intercepto",
    formula: "b = 3,774.92",
    explanation: "Costos fijos del mercado (manejo, transporte, márgenes).",
  },
];

const impactMetrics = [
  { metric: "93.9%", label: "Precisión del modelo" },
  { metric: "1,119", label: "Registros analizados" },
  { metric: "100%", label: "Acceso gratuito" },
  { metric: "0.000s", label: "Tiempo de cálculo" },
];
---

<Layout>
  <HeroTitle text="MIGANADO" size="text-[10vw]" />

  <!-- Summary -->
  <BaseSection className="text-center py-20">
    <p class="lead">
      Calculadora inteligente para la estimación del precio de ganado bovino, basada en
      regresión lineal simple entrenada con datos oficiales del SNIIM.
    </p>
    <div class="pill-row">
      {techStack.map((t) => <TechnologyButton icon={t.icon} label={t.name} />)}
    </div>
    <ProjectCTA demo="https://cesars39.github.io/MiGanado/" repo="https://github.com/CesarS39/MiGanado" />
  </BaseSection>

  <!-- Problem / Solution -->
  <BaseSection>
    <p class="eyebrow">El reto</p>
    <h2 class="section-title">Democratizando la información ganadera</h2>

    <div class="compare-grid">
      <div class="compare-col">
        <h3 class="compare-label">Problema identificado</h3>
        <ul class="compare-list">
          <li>Asimetría de información en el sector ganadero</li>
          <li>Dependencia de intermediarios para conocer precios</li>
          <li>Falta de acceso a herramientas de valoración</li>
          <li>Riesgo de negociar por debajo del precio justo</li>
        </ul>
      </div>
      <div class="compare-col">
        <h3 class="compare-label compare-label--accent">Solución MiGanado</h3>
        <ul class="compare-list">
          <li>Herramienta gratuita y accesible</li>
          <li>Estimación basada en datos oficiales</li>
          <li>Cálculo instantáneo y transparente</li>
          <li>Empoderamiento del productor ganadero</li>
        </ul>
      </div>
    </div>
  </BaseSection>

  <!-- Regression model -->
  <BaseSection>
    <p class="eyebrow">Modelo</p>
    <h2 class="section-title">Regresión lineal simple</h2>

    <div class="arch-grid">
      {regressionDetails.map((d) => (
        <div class="arch-col">
          <h4 class="arch-label">{d.concept}</h4>
          <p class="formula">{d.formula}</p>
          <p>{d.explanation}</p>
        </div>
      ))}
    </div>
  </BaseSection>

  <!-- Features -->
  <BaseSection>
    <p class="eyebrow">Características</p>
    <h2 class="section-title">Lo más relevante</h2>

    <div class="feature-grid">
      {features.map((f, i) => (
        <FeatureCard index={i + 1} title={f.title} description={f.description} />
      ))}
    </div>
  </BaseSection>

  <!-- Impact -->
  <BaseSection>
    <p class="eyebrow">Impacto</p>
    <h2 class="section-title">Métricas del sistema</h2>

    <div class="stat-grid">
      {impactMetrics.map((m) => (
        <div class="stat-item">
          <span class="stat-value">{m.metric}</span>
          <span class="stat-label">{m.label}</span>
        </div>
      ))}
    </div>
  </BaseSection>

  <!-- Technical implementation -->
  <BaseSection>
    <p class="eyebrow">Implementación</p>
    <h2 class="section-title">Fuente de datos y algoritmo</h2>

    <div class="arch-grid arch-grid--2">
      <div class="arch-col">
        <h4 class="arch-label">Fuente de datos</h4>
        <p>Sistema Nacional de Información de Mercados (SNIIM) · 1,119 registros de ganado bovino en canal (enero-julio 2025) · Variable X: peso en canal (kg) · Variable Y: precio total (MXN)</p>
      </div>
      <div class="arch-col">
        <h4 class="arch-label">Algoritmo de ML</h4>
        <p>Regresión lineal simple por método de mínimos cuadrados · implementación directa en el frontend, sin dependencias externas</p>
      </div>
    </div>

    <div class="code-block">
      <div class="code-header">
        <span>JavaScript</span>
        <span>Función de predicción</span>
      </div>
      <pre><code>{`// Parámetros del modelo de regresión lineal
const REGRESSION_SLOPE = 102.53;      // Pendiente (m)
const REGRESSION_INTERCEPT = 3774.92; // Intercepto (b)

// Función de predicción: y = mx + b
function calculateTotalPrice(weight) {
  return (REGRESSION_SLOPE * weight) + REGRESSION_INTERCEPT;
}

// Cálculo del precio por kilogramo
function calculatePricePerKg(totalPrice, weight) {
  return totalPrice / weight;
}`}</code></pre>
    </div>
  </BaseSection>

  <!-- Future scalability -->
  <BaseSection>
    <p class="eyebrow">Roadmap</p>
    <h2 class="section-title">Escalabilidad y futuras mejoras</h2>

    <div class="compare-grid">
      <div class="compare-col">
        <h3 class="compare-label">Mejoras técnicas</h3>
        <ul class="compare-list">
          <li>Modelo multivariable (raza, región, edad)</li>
          <li>API para integración con otros sistemas</li>
          <li>Base de datos en tiempo real</li>
          <li>Machine learning más avanzado</li>
        </ul>
      </div>
      <div class="compare-col">
        <h3 class="compare-label compare-label--accent">Expansión del negocio</h3>
        <ul class="compare-list">
          <li>Otros tipos de ganado (porcino, ovino)</li>
          <li>Mercados agrícolas adicionales</li>
          <li>Plataforma integral para productores</li>
          <li>Expansión internacional</li>
        </ul>
      </div>
    </div>
  </BaseSection>

  <style>
    .lead {
      font-family: 'Inter', sans-serif;
      font-size: 1.1rem;
      line-height: 1.7;
      color: #999;
      max-width: 42rem;
      margin: 0 auto 2rem;
    }

    .pill-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.6rem;
      margin-bottom: 2.5rem;
    }

    .eyebrow {
      font-family: 'Inter', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #444;
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      letter-spacing: -0.03em;
      color: #f0f0f0;
      margin-bottom: 2.5rem;
    }

    .compare-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .compare-label {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      color: #888;
      margin-bottom: 1rem;
    }
    .compare-label--accent { color: #e2e8f0; }

    .compare-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .compare-list li {
      font-family: 'Inter', sans-serif;
      font-size: 0.88rem;
      color: #888;
      padding-left: 1.1rem;
      position: relative;
      line-height: 1.5;
    }
    .compare-list li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: #444;
    }

    .arch-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
    .arch-grid--2 {
      grid-template-columns: repeat(2, 1fr);
      margin-bottom: 2rem;
    }
    .arch-label {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.95rem;
      color: #e2e8f0;
      margin-bottom: 0.6rem;
    }
    .arch-col p {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      line-height: 1.7;
      color: #777;
    }
    .formula {
      font-family: 'Inter', monospace;
      font-size: 0.95rem;
      font-weight: 700;
      color: #c0c0c0 !important;
      margin-bottom: 0.5rem;
    }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
    .stat-item {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      padding-top: 1rem;
    }
    .stat-value {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.8rem;
      color: #f0f0f0;
    }
    .stat-label {
      font-family: 'Inter', sans-serif;
      font-size: 0.8rem;
      color: #888;
    }

    .code-block {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.08);
      padding: 1.5rem;
    }
    .code-header {
      display: flex;
      justify-content: space-between;
      font-family: 'Inter', sans-serif;
      font-size: 0.75rem;
      color: #666;
      margin-bottom: 1rem;
    }
    .code-block pre {
      font-family: 'SF Mono', 'Consolas', monospace;
      font-size: 0.82rem;
      line-height: 1.6;
      color: #b0b0b0;
      overflow-x: auto;
    }

    @media (max-width: 640px) {
      .compare-grid, .arch-grid, .feature-grid { grid-template-columns: 1fr; }
      .stat-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</Layout>
