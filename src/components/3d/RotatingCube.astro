---
---
<canvas id="cube-canvas" aria-hidden="true"></canvas>

<style>
  #cube-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
  import * as THREE from "three";

  const canvas = document.getElementById("cube-canvas") as HTMLCanvasElement;

  function onVisible(cb: () => void) {
    const main = document.getElementById("main-content");
    if (!main || main.style.display === "block") { setTimeout(cb, 50); return; }
    let done = false;
    const fire = () => { if (done) return; done = true; setTimeout(cb, 60); };
    const obs = new MutationObserver(() => {
      if (main.style.display === "block") { obs.disconnect(); fire(); }
    });
    obs.observe(main, { attributes: true, attributeFilter: ["style"] });
    setTimeout(() => { obs.disconnect(); fire(); }, 2700);
  }

  onVisible(() => {
    const W = canvas.offsetWidth  || canvas.clientWidth  || 400;
    const H = canvas.offsetHeight || canvas.clientHeight || 380;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
    renderer.setSize(W, H, false);
    renderer.setClearColor(0x000000, 0);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, W / H, 0.1, 100);
    camera.position.set(0, 1.2, 6.0);
    camera.lookAt(0, 0, 0);

    function resize() {
      const rw = canvas.offsetWidth, rh = canvas.offsetHeight;
      if (!rw || !rh) return;
      renderer.setSize(rw, rh, false);
      camera.aspect = rw / rh;
      camera.updateProjectionMatrix();
    }
    new ResizeObserver(resize).observe(canvas);

    const MAT = (opacity: number) =>
      new THREE.MeshBasicMaterial({ color: 0xdde3ec, wireframe: true, transparent: true, opacity });
    const MAT_SOLID = (color: number, opacity: number) =>
      new THREE.MeshBasicMaterial({ color, transparent: true, opacity });

    // ── Planet (Earth) ───────────────────────────────────────────────────
    const earthSolid = new THREE.Mesh(
      new THREE.SphereGeometry(1.02, 32, 20),
      MAT_SOLID(0x0c1220, 0.92)
    );
    scene.add(earthSolid);

    const earthWire = new THREE.Mesh(
      new THREE.SphereGeometry(1.02, 22, 14),
      MAT(0.50)
    );
    scene.add(earthWire);

    // Atmosphere glow shell
    const atmo = new THREE.Mesh(
      new THREE.SphereGeometry(1.14, 18, 10),
      MAT_SOLID(0x8ab4c8, 0.06)
    );
    scene.add(atmo);

    // ── Orbital rings ────────────────────────────────────────────────────
    function makeRing(radius: number, rotX: number, rotZ: number) {
      const m = new THREE.Mesh(
        new THREE.TorusGeometry(radius, 0.007, 4, 80),
        MAT_SOLID(0xdde3ec, 0.18)
      );
      m.rotation.x = rotX;
      m.rotation.z = rotZ;
      scene.add(m);
      return m;
    }

    const ring1 = makeRing(1.85, Math.PI / 2, 0);
    const ring2 = makeRing(2.30, Math.PI / 2 - 0.55, 0.3);
    const ring3 = makeRing(2.70, Math.PI / 2 + 0.4, -0.2);

    // ── Satellites ───────────────────────────────────────────────────────
    function makeSat(size = 0.10) {
      const g = new THREE.Group();
      // Body
      const body = new THREE.Mesh(
        new THREE.IcosahedronGeometry(size, 0),
        MAT(0.80)
      );
      g.add(body);
      // Solar panel (thin box, one side)
      const panel = new THREE.Mesh(
        new THREE.BoxGeometry(size * 2.6, size * 0.12, size * 0.8),
        MAT_SOLID(0xdde3ec, 0.30)
      );
      panel.position.x = size * 1.5;
      g.add(panel);
      scene.add(g);
      return g;
    }

    const sat1 = makeSat(0.09);
    const sat2 = makeSat(0.08);
    const sat3 = makeSat(0.10);
    const sat4 = makeSat(0.07);

    // Orbit parameters: [ring, radius, speed, startAngle, tiltX, tiltZ]
    const orbits = [
      { sat: sat1, r: 1.85, speed: 0.65, a: 0,            rx: Math.PI/2,       rz: 0 },
      { sat: sat2, r: 2.30, speed: -0.42, a: Math.PI*0.7, rx: Math.PI/2-0.55,  rz: 0.3 },
      { sat: sat3, r: 2.70, speed: 0.30, a: Math.PI*1.4,  rx: Math.PI/2+0.4,   rz: -0.2 },
      { sat: sat4, r: 2.00, speed: -0.55, a: Math.PI*0.3, rx: Math.PI/2-0.2,   rz: 0.5 },
    ];

    // Helper: orbit position given angle + orbital plane
    function orbitPos(r: number, angle: number, rx: number, rz: number) {
      const x = Math.cos(angle) * r;
      const y = Math.sin(angle) * r;
      const v = new THREE.Vector3(x, y, 0);
      v.applyEuler(new THREE.Euler(rx, 0, rz));
      return v;
    }

    // ── Signal beams & flashes ───────────────────────────────────────────
    interface Signal {
      mesh: THREE.Mesh;
      trail: THREE.Mesh;
      from: THREE.Vector3;
      progress: number;
      speed: number;
    }
    interface Flash {
      mesh: THREE.Mesh;
      life: number;
      dur: number;
    }

    const signals: Signal[] = [];
    const flashes: Flash[]  = [];
    let   signalCooldown    = 1.5;

    function spawnSignal(from: THREE.Vector3) {
      // Traveling dot
      const dot = new THREE.Mesh(
        new THREE.SphereGeometry(0.045, 6, 6),
        new THREE.MeshBasicMaterial({ color: 0xe2e8f0, transparent: true, opacity: 0.9 })
      );
      dot.position.copy(from);

      // Faint tail sphere (larger, lower opacity)
      const trail = new THREE.Mesh(
        new THREE.SphereGeometry(0.07, 6, 6),
        new THREE.MeshBasicMaterial({ color: 0xdde3ec, transparent: true, opacity: 0.20 })
      );
      trail.position.copy(from);

      scene.add(dot);
      scene.add(trail);
      signals.push({ mesh: dot, trail, from: from.clone(), progress: 0, speed: 0.7 + Math.random() * 0.4 });
    }

    function spawnFlash(pos: THREE.Vector3) {
      // Expanding ring
      const ring = new THREE.Mesh(
        new THREE.TorusGeometry(0.12, 0.025, 6, 24),
        new THREE.MeshBasicMaterial({ color: 0xe2e8f0, transparent: true, opacity: 0.85 })
      );
      ring.position.copy(pos);
      ring.rotation.x = Math.random() * Math.PI;
      ring.rotation.y = Math.random() * Math.PI;
      scene.add(ring);
      flashes.push({ mesh: ring, life: 0, dur: 0.55 });
    }

    const earthCenter = new THREE.Vector3(0, 0, 0);
    const clock = new THREE.Clock();

    (function animate() {
      requestAnimationFrame(animate);
      const d = clock.getDelta();

      // Slow earth rotation
      earthWire.rotation.y  += d * 0.12;
      earthSolid.rotation.y += d * 0.12;

      // Orbit satellites
      orbits.forEach(o => {
        o.a += d * o.speed;
        const p = orbitPos(o.r, o.a, o.rx, o.rz);
        o.sat.position.copy(p);
        o.sat.rotation.y += d * 1.2;
      });

      // Signal spawn
      signalCooldown -= d;
      if (signalCooldown <= 0) {
        signalCooldown = 1.2 + Math.random() * 1.8;
        const pick = orbits[Math.floor(Math.random() * orbits.length)];
        spawnSignal(pick.sat.position.clone());
      }

      // Animate signals
      for (let i = signals.length - 1; i >= 0; i--) {
        const s = signals[i];
        s.progress += d * s.speed;
        if (s.progress >= 1) {
          // Impact flash at earth surface
          const dir = s.from.clone().normalize();
          spawnFlash(dir.multiplyScalar(1.05));
          scene.remove(s.mesh);
          scene.remove(s.trail);
          signals.splice(i, 1);
        } else {
          s.mesh.position.lerpVectors(s.from, earthCenter, s.progress);
          // Trail lags behind
          const lagT = Math.max(0, s.progress - 0.12);
          s.trail.position.lerpVectors(s.from, earthCenter, lagT);
          // Fade signal dot as it approaches earth
          (s.mesh.material as THREE.MeshBasicMaterial).opacity = 0.9 * (1 - s.progress * 0.4);
        }
      }

      // Animate flashes
      for (let i = flashes.length - 1; i >= 0; i--) {
        const f = flashes[i];
        f.life += d;
        const t = f.life / f.dur;
        if (t >= 1) {
          scene.remove(f.mesh);
          flashes.splice(i, 1);
        } else {
          f.mesh.scale.setScalar(1 + t * 4.5);
          (f.mesh.material as THREE.MeshBasicMaterial).opacity = 0.85 * (1 - t);
        }
      }

      renderer.render(scene, camera);
    })();
  });
</script>
