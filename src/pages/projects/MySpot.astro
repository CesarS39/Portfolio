---
import Layout from "../../layouts/Layout.astro";
import GalleryComponent from "../../components/organisms/GalleryComponent.astro";
import HeroTitle from "../../components/atoms/HeroTitle.astro";
import BaseSection from "../../components/atoms/BaseSection.astro";
import TechnologyButton from "../../components/molecules/TechnologyButton.astro";
import FeatureCard from "../../components/molecules/FeatureCard.astro";
import ProjectCTA from "../../components/molecules/ProjectCTA.astro";

const screenshots: string[] = [
  "/Portfolio/images/projects/myspot/IMG_5053.webp",
  "/Portfolio/images/projects/myspot/IMG_5055.webp",
  "/Portfolio/images/projects/myspot/IMG_5057.webp",
  "/Portfolio/images/projects/myspot/IMG_5059.webp",
  "/Portfolio/images/projects/myspot/IMG_5061.webp",
  "/Portfolio/images/projects/myspot/IMG_5063.webp",
];

const techStack = [
  { name: "Flutter", icon: "devicon-flutter-plain" },
  { name: "Firebase", icon: "devicon-firebase-plain" },
  { name: "FastAPI" },
  { name: "MongoDB", icon: "devicon-mongodb-plain" },
];

const features = [
  {
    title: "Descubrimiento social de lugares",
    description: "Explora lugares por categorías con calificaciones reales de usuarios y reseñas tipo red social, geolocalización y búsqueda predictiva.",
  },
  {
    title: "Experiencia iOS nativa",
    description: "Diseño crafteado siguiendo Human Interface Guidelines con Flutter: animaciones fluidas, gestos intuitivos y adaptación dark/light.",
  },
  {
    title: "Sistema de gamificación",
    description: "Insignias dinámicas que reconocen la participación activa, logros por actividad y rankings locales.",
  },
  {
    title: "Arquitectura escalable",
    description: "Backend híbrido Firebase + FastAPI con microservicios, NoSQL optimizado y CDN para imágenes.",
  },
];

const process = [
  { title: "Registro rápido", desc: "Login con Google/Apple en segundos, sin formularios complejos, directo a explorar." },
  { title: "Explorar y descubrir", desc: "Navega por categorías, descubre lugares cercanos y lee reseñas auténticas de la comunidad." },
  { title: "Participar y calificar", desc: "Comparte tu experiencia, sube fotos, califica lugares y participa en discusiones tipo red social." },
  { title: "Ganar reconocimiento", desc: "Obtén insignias por tu participación activa y conviértete en un referente local de confianza." },
];
---

<Layout>
  <HeroTitle text="MYSPOT" size="text-[10vw]" />

  <!-- Summary -->
  <BaseSection className="text-center py-20">
    <p class="lead">
      Plataforma social móvil que conecta usuarios con los mejores lugares de su ciudad.
      Descubre, califica y comparte experiencias con una comunidad local activa.
    </p>
    <div class="pill-row">
      {techStack.map((t) => <TechnologyButton icon={t.icon} label={t.name} />)}
    </div>
    <p class="status-note">En desarrollo activo — iOS y Android al 60%. Launch estimado Q1 2026.</p>
    <ProjectCTA repo="https://github.com/CesarS39/MySpot_App" />
  </BaseSection>

  <!-- Problem / Solution -->
  <BaseSection>
    <p class="eyebrow">El reto</p>
    <h2 class="section-title">Conectando comunidades locales</h2>

    <div class="compare-grid">
      <div class="compare-col">
        <h3 class="compare-label">Problema identificado</h3>
        <ul class="compare-list">
          <li>Información dispersa sobre lugares locales</li>
          <li>Reseñas poco confiables en plataformas generales</li>
          <li>Falta de comunidad local organizada</li>
          <li>Descubrimiento limitado de nuevos lugares</li>
        </ul>
      </div>
      <div class="compare-col">
        <h3 class="compare-label compare-label--accent">Solución MySpot</h3>
        <ul class="compare-list">
          <li>Plataforma centralizada y especializada</li>
          <li>Sistema de reputación con insignias</li>
          <li>Comunidad verificada y activa</li>
          <li>Descubrimiento inteligente por categorías</li>
        </ul>
      </div>
    </div>
  </BaseSection>

  <!-- Architecture -->
  <BaseSection>
    <p class="eyebrow">Arquitectura</p>
    <h2 class="section-title">Stack híbrido</h2>

    <div class="arch-grid">
      <div class="arch-col">
        <h4 class="arch-label">Frontend móvil</h4>
        <p>Flutter con diseño iOS nativo · Figma para prototipado · gestión de estado avanzada · animaciones fluidas</p>
      </div>
      <div class="arch-col">
        <h4 class="arch-label">Backend híbrido</h4>
        <p>Firebase para auth y realtime · FastAPI para lógica compleja · MongoDB para datos NoSQL · Supabase Storage para media</p>
      </div>
      <div class="arch-col">
        <h4 class="arch-label">DevOps &amp; tools</h4>
        <p>GitHub con repositorio privado · gestión de tareas por usuario · CI/CD para deployment · monitoring y analytics</p>
      </div>
    </div>
  </BaseSection>

  <!-- Features -->
  <BaseSection>
    <p class="eyebrow">Características</p>
    <h2 class="section-title">Lo más relevante</h2>

    <div class="feature-grid">
      {features.map((f, i) => (
        <FeatureCard index={i + 1} title={f.title} description={f.description} />
      ))}
    </div>
  </BaseSection>

  <!-- Process / user flow -->
  <BaseSection>
    <p class="eyebrow">Experiencia</p>
    <h2 class="section-title">Flujo de usuario</h2>

    <div class="process-list">
      {process.map((step, i) => (
        <div class="process-item">
          <span class="process-num">{String(i + 1).padStart(2, "0")}</span>
          <div>
            <h3 class="process-title">{step.title}</h3>
            <p class="process-desc">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </BaseSection>

  <!-- Gallery -->
  <BaseSection>
    <p class="eyebrow">Capturas</p>
    <h2 class="section-title">La app en desarrollo</h2>
    <GalleryComponent images={screenshots} />
  </BaseSection>

  <style>
    .lead {
      font-family: 'Inter', sans-serif;
      font-size: 1.1rem;
      line-height: 1.7;
      color: #999;
      max-width: 42rem;
      margin: 0 auto 2rem;
    }

    .pill-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.6rem;
      margin-bottom: 1.5rem;
    }

    .status-note {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      color: #777;
      max-width: 32rem;
      margin: 0 auto 2rem;
    }

    .eyebrow {
      font-family: 'Inter', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #444;
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      letter-spacing: -0.03em;
      color: #f0f0f0;
      margin-bottom: 2.5rem;
    }

    .compare-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .compare-label {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      color: #888;
      margin-bottom: 1rem;
    }
    .compare-label--accent { color: #e2e8f0; }

    .compare-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .compare-list li {
      font-family: 'Inter', sans-serif;
      font-size: 0.88rem;
      color: #888;
      padding-left: 1.1rem;
      position: relative;
      line-height: 1.5;
    }
    .compare-list li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: #444;
    }

    .arch-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
    .arch-label {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.95rem;
      color: #e2e8f0;
      margin-bottom: 0.6rem;
    }
    .arch-col p {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      line-height: 1.7;
      color: #777;
    }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .process-list {
      display: flex;
      flex-direction: column;
    }
    .process-item {
      display: flex;
      gap: 1.5rem;
      padding: 1.5rem 0;
      border-top: 1px solid rgba(255, 255, 255, 0.07);
    }
    .process-item:last-child { border-bottom: 1px solid rgba(255, 255, 255, 0.07); }
    .process-num {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      color: #333;
      flex-shrink: 0;
      width: 2rem;
    }
    .process-title {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1.05rem;
      color: #f0f0f0;
      margin-bottom: 0.4rem;
    }
    .process-desc {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      color: #888;
      line-height: 1.6;
    }

    @media (max-width: 640px) {
      .compare-grid, .arch-grid, .feature-grid { grid-template-columns: 1fr; }
    }
  </style>
</Layout>
