---
import Layout from "../../layouts/Layout.astro";
import GalleryComponent from "../../components/organisms/GalleryComponent.astro";
import HeroTitle from "../../components/atoms/HeroTitle.astro";
import BaseSection from "../../components/atoms/BaseSection.astro";
import TechnologyButton from "../../components/molecules/TechnologyButton.astro";
import FeatureCard from "../../components/molecules/FeatureCard.astro";
import ProjectCTA from "../../components/molecules/ProjectCTA.astro";

const screenshots: string[] = [
  "/Portfolio/images/projects/pockbit/pockbit.webp",
  "/Portfolio/images/projects/pockbit/login.webp",
  "/Portfolio/images/projects/pockbit/dashboard.webp",
  "/Portfolio/images/projects/pockbit/compras.webp",
  "/Portfolio/images/projects/pockbit/laboratorios.webp",
  "/Portfolio/images/projects/pockbit/medicamentos.webp"
];

const techStack = [
  { name: ".NET Framework", icon: "devicon-dotnetcore-plain" },
  { name: "C#", icon: "devicon-csharp-plain" },
  { name: "SQL Server", icon: "devicon-microsoftsqlserver-plain" },
  { name: "Azure", icon: "devicon-azure-plain" },
  { name: "Bootstrap", icon: "devicon-bootstrap-plain" },
];

const features = [
  {
    title: "Gestión farmacéutica especializada",
    description: "Control de caducidades por lote, precios máximos y trazabilidad completa de medicamentos.",
  },
  {
    title: "Arquitectura empresarial",
    description: "Transacciones ACID, normalización 3FN, CQRS para reportes y capas separadas.",
  },
  {
    title: "Integridad de datos",
    description: "Validaciones multicapa, rollback automático y consistencia garantizada.",
  },
  {
    title: "Escalabilidad empresarial",
    description: "Multi-sucursal, componentes desacoplados e infraestructura cloud-ready.",
  },
];

const before = [
  "Operación manual con Excel",
  "Errores frecuentes en inventario",
  "Información desactualizada",
  "Procesos lentos e ineficientes",
];
const after = [
  "Automatización completa",
  "Operación simultánea multi-usuario",
  "Reportes automáticos en tiempo real",
  "Validaciones y controles de integridad",
];

const process = [
  { title: "Análisis con cliente", desc: "Identificación de necesidades del sector farmacéutico y mapeo de procesos existentes." },
  { title: "Diseño de arquitectura", desc: "Modelado de datos, definición de capas y selección del stack tecnológico." },
  { title: "Desarrollo iterativo", desc: "Implementación con pruebas continuas y validación constante de funcionalidades." },
  { title: "Validación y despliegue", desc: "Pruebas con usuarios reales, ajustes finales y despliegue en Azure Cloud." },
];
---

<Layout>
  <HeroTitle text="POCKBIT" size="text-[10vw]" />

  <!-- Summary -->
  <BaseSection className="text-center py-20">
    <p class="lead">
      Sistema integral de punto de venta diseñado específicamente para distribuidoras farmacéuticas,
      transformando operaciones manuales en procesos automatizados y eficientes.
    </p>
    <div class="pill-row">
      {techStack.map((t) => <TechnologyButton icon={t.icon} label={t.name} />)}
    </div>
    <ProjectCTA repo="https://github.com/CesarS39/Pockbit_v2" />
  </BaseSection>

  <!-- Problem / Solution -->
  <BaseSection>
    <p class="eyebrow">El reto</p>
    <h2 class="section-title">Transformando el negocio farmacéutico</h2>

    <div class="compare-grid">
      <div class="compare-col">
        <h3 class="compare-label">Situación anterior</h3>
        <ul class="compare-list">
          {before.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="compare-col">
        <h3 class="compare-label compare-label--accent">Solución Pockbit</h3>
        <ul class="compare-list">
          {after.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </BaseSection>

  <!-- Architecture -->
  <BaseSection>
    <p class="eyebrow">Arquitectura</p>
    <h2 class="section-title">Stack y herramientas</h2>

    <div class="arch-grid">
      <div class="arch-col">
        <h4 class="arch-label">Backend</h4>
        <p>C# con .NET Framework · patrón MVC · lógica de negocio separada · DAOs y DTOs</p>
      </div>
      <div class="arch-col">
        <h4 class="arch-label">Base de datos</h4>
        <p>SQL Server · Azure SQL Database · procedimientos almacenados · vistas optimizadas</p>
      </div>
      <div class="arch-col">
        <h4 class="arch-label">Frontend & cloud</h4>
        <p>Bootstrap + JavaScript · diseño responsivo · Azure App Service · despliegue automático</p>
      </div>
    </div>
  </BaseSection>

  <!-- Features -->
  <BaseSection>
    <p class="eyebrow">Características</p>
    <h2 class="section-title">Lo más relevante</h2>

    <div class="feature-grid">
      {features.map((f, i) => (
        <FeatureCard index={i + 1} title={f.title} description={f.description} />
      ))}
    </div>
  </BaseSection>

  <!-- Process -->
  <BaseSection>
    <p class="eyebrow">Proceso</p>
    <h2 class="section-title">Cómo se construyó</h2>

    <div class="process-list">
      {process.map((step, i) => (
        <div class="process-item">
          <span class="process-num">{String(i + 1).padStart(2, "0")}</span>
          <div>
            <h3 class="process-title">{step.title}</h3>
            <p class="process-desc">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </BaseSection>

  <!-- Gallery -->
  <BaseSection>
    <p class="eyebrow">Capturas</p>
    <h2 class="section-title">El sistema en uso</h2>
    <GalleryComponent images={screenshots} />
  </BaseSection>

  <style>
    .lead {
      font-family: 'Inter', sans-serif;
      font-size: 1.1rem;
      line-height: 1.7;
      color: #999;
      max-width: 42rem;
      margin: 0 auto 2rem;
    }

    .pill-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.6rem;
      margin-bottom: 2.5rem;
    }

    .eyebrow {
      font-family: 'Inter', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #444;
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      letter-spacing: -0.03em;
      color: #f0f0f0;
      margin-bottom: 2.5rem;
    }

    .compare-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .compare-label {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      color: #888;
      margin-bottom: 1rem;
    }
    .compare-label--accent { color: #e2e8f0; }

    .compare-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .compare-list li {
      font-family: 'Inter', sans-serif;
      font-size: 0.88rem;
      color: #888;
      padding-left: 1.1rem;
      position: relative;
      line-height: 1.5;
    }
    .compare-list li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: #444;
    }

    .arch-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
    .arch-label {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.95rem;
      color: #e2e8f0;
      margin-bottom: 0.6rem;
    }
    .arch-col p {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      line-height: 1.7;
      color: #777;
    }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .process-list {
      display: flex;
      flex-direction: column;
    }
    .process-item {
      display: flex;
      gap: 1.5rem;
      padding: 1.5rem 0;
      border-top: 1px solid rgba(255, 255, 255, 0.07);
    }
    .process-item:last-child { border-bottom: 1px solid rgba(255, 255, 255, 0.07); }
    .process-num {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      color: #333;
      flex-shrink: 0;
      width: 2rem;
    }
    .process-title {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1.05rem;
      color: #f0f0f0;
      margin-bottom: 0.4rem;
    }
    .process-desc {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      color: #888;
      line-height: 1.6;
    }

    @media (max-width: 640px) {
      .compare-grid, .arch-grid, .feature-grid { grid-template-columns: 1fr; }
    }
  </style>
</Layout>
