---
interface Interest {
  title: string;
  description: string;
  image: string;
  className?: string;
}

const { interests } = Astro.props as { interests: Interest[] };
---

<section id="intereses" class="reveal-section interests-section">
  <div class="interests-inner">

    <div class="interests-header">
      <p class="interests-label">Más allá del código</p>
      <h2 class="interests-heading">Intereses</h2>
    </div>

    <div class="bento-grid">
      {interests.map((item, i) => (
        <div class={`bento-card bento-card--${i}`}>
          <img
            loading="lazy"
            src={item.image}
            alt={item.title}
            class="bento-img"
          />
          <div class="bento-overlay"></div>
          <div class="bento-content">
            <h3 class="bento-title">{item.title}</h3>
            <p class="bento-desc">{item.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .interests-section {
    padding: 3rem 1.5rem;
    background: #080808;
  }

  .interests-inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .interests-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #666;
    margin-bottom: 1rem;
  }

  .interests-heading {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    letter-spacing: -0.03em;
    color: #f0f0f0;
    margin-bottom: 2rem;
  }

  /* ── Bento grid: 3 columns ── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 180px;
    gap: 1px;
    background: rgba(255, 255, 255, 0.04);
  }

  /* First card wide, second and third normal */
  .bento-card--0 { grid-column: span 2; }
  /* Cards 1, 2 are 1 col each — default */

  /* Fourth card wide on second row */
  .bento-card--3 { grid-column: span 2; grid-column-start: 2; }
  /* Fifth card 1 col — default */

  .bento-card {
    position: relative;
    overflow: hidden;
    background: #0f0f0f;
    min-height: 180px;
  }

  /* ── Image ── */
  .bento-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease;
    opacity: 0.7;
  }

  .bento-card:hover .bento-img {
    opacity: 0.3;
  }

  /* ── Dark gradient overlay ── */
  .bento-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8,8,8,0.9) 0%, rgba(8,8,8,0.1) 50%, transparent 100%);
  }

  /* ── Content ── */
  .bento-content {
    position: absolute;
    inset: 0;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .bento-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #f0f0f0;
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
  }

  .bento-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: #777;
    line-height: 1.5;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bento-card:hover .bento-desc {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Mobile: single column ── */
  @media (max-width: 640px) {
    .bento-grid {
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 150px;
    }

    .bento-card--0,
    .bento-card--3 {
      grid-column: span 2;
      grid-column-start: auto;
    }

    .bento-desc { opacity: 1; transform: translateY(0); }
  }
</style>
