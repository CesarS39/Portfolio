---
import Layout from "../../layouts/Layout.astro";
import GalleryComponent from "../../components/organisms/GalleryComponent.astro";
import HeroTitle from "../../components/atoms/HeroTitle.astro";
import BaseSection from "../../components/atoms/BaseSection.astro";
import TechnologyButton from "../../components/molecules/TechnologyButton.astro";
import FeatureCard from "../../components/molecules/FeatureCard.astro";

const screenshots: string[] = [
  "/Portfolio/images/projects/notiontennis/main.webp",
  "/Portfolio/images/projects/notiontennis/Registro de asistencia.webp",
  "/Portfolio/images/projects/notiontennis/estudiante.webp",
  "/Portfolio/images/projects/notiontennis/resumenfecha.webp",
  "/Portfolio/images/projects/notiontennis/grafico1.webp",
  "/Portfolio/images/projects/notiontennis/grafico2.webp"
];

const techStack = [
  { name: "Notion" },
  { name: "No-Code" },
  { name: "Automatización" },
  { name: "Analytics" },
];

const features = [
  {
    title: "Gestión de asistencias automatizada",
    description: "Pase de lista digital con seguimiento en tiempo real, notificaciones automáticas y reportes de participación estudiantil.",
  },
  {
    title: "Administración de eventos",
    description: "Organización de torneos, entrenamientos y actividades especiales con calendario integrado y gestión de participantes.",
  },
  {
    title: "Sistema de calificaciones",
    description: "Evaluación del rendimiento deportivo con métricas personalizadas y seguimiento del progreso individual.",
  },
  {
    title: "Análisis estadístico avanzado",
    description: "Dashboard con KPIs clave, tendencias de participación y métricas para la toma de decisiones.",
  },
];

const impactMetrics = [
  { metric: "85%", label: "Reducción de tiempo en procesos administrativos" },
  { metric: "100%", label: "Automatización del pase de lista y reportes" },
  { metric: "100+", label: "Estudiantes beneficiados directamente" },
];

const process = [
  { title: "Análisis de necesidades", desc: "Identificación de procesos manuales existentes y requerimientos específicos del programa de tenis universitario." },
  { title: "Diseño de arquitectura", desc: "Estructuración de bases de datos, definición de flujos de trabajo y diseño de interfaces en Notion." },
  { title: "Desarrollo e integración", desc: "Implementación de módulos, configuración de automatizaciones y creación de dashboards para análisis de datos." },
  { title: "Capacitación y puesta en marcha", desc: "Entrenamiento del personal, pruebas piloto y ajustes finales basados en retroalimentación de usuarios." },
];
---

<Layout>
  <HeroTitle text="NOTION TENNIS UPP" size="text-[8vw]" />

  <!-- Summary -->
  <BaseSection className="text-center py-20">
    <p class="lead">
      Sistemas no-code desarrollados durante el servicio social para optimizar la gestión del
      extracurricular de tenis en la Universidad Politécnica de Pachuca, transformando procesos
      manuales en flujos automatizados eficientes.
    </p>
    <div class="pill-row">
      {techStack.map((t) => <TechnologyButton icon={t.icon} label={t.name} />)}
    </div>
  </BaseSection>

  <!-- Problem / Solution -->
  <BaseSection>
    <p class="eyebrow">El reto</p>
    <h2 class="section-title">Modernizando la gestión deportiva universitaria</h2>

    <div class="compare-grid">
      <div class="compare-col">
        <h3 class="compare-label">Situación anterior</h3>
        <ul class="compare-list">
          <li>Pase de lista manual con papel</li>
          <li>Registro desorganizado de eventos</li>
          <li>Calificaciones en hojas dispersas</li>
          <li>Sin análisis de datos ni métricas</li>
          <li>Toma de decisiones sin base estadística</li>
        </ul>
      </div>
      <div class="compare-col">
        <h3 class="compare-label compare-label--accent">Solución no-code</h3>
        <ul class="compare-list">
          <li>Sistema digital automatizado</li>
          <li>Gestión centralizada de información</li>
          <li>Reportes automáticos en tiempo real</li>
          <li>Dashboard con métricas clave</li>
          <li>Decisiones basadas en datos</li>
        </ul>
      </div>
    </div>
  </BaseSection>

  <!-- Architecture -->
  <BaseSection>
    <p class="eyebrow">Arquitectura</p>
    <h2 class="section-title">Componentes y funcionalidades</h2>

    <div class="arch-grid">
      <div class="arch-col">
        <h4 class="arch-label">Gestión de datos</h4>
        <p>Bases de datos relacionales · formularios personalizados · validación automática · backup y sincronización</p>
      </div>
      <div class="arch-col">
        <h4 class="arch-label">Automatización</h4>
        <p>Flujos de trabajo automáticos · notificaciones inteligentes · recordatorios programados · actualizaciones en tiempo real</p>
      </div>
      <div class="arch-col">
        <h4 class="arch-label">Análisis &amp; reportes</h4>
        <p>Dashboard interactivo · gráficos y métricas · reportes automáticos · exportación de datos</p>
      </div>
    </div>
  </BaseSection>

  <!-- Features -->
  <BaseSection>
    <p class="eyebrow">Módulos</p>
    <h2 class="section-title">El sistema en detalle</h2>

    <div class="feature-grid">
      {features.map((f, i) => (
        <FeatureCard index={i + 1} title={f.title} description={f.description} />
      ))}
    </div>
  </BaseSection>

  <!-- Impact -->
  <BaseSection>
    <p class="eyebrow">Impacto</p>
    <h2 class="section-title">Resultados obtenidos</h2>

    <div class="stat-grid">
      {impactMetrics.map((m) => (
        <div class="stat-item">
          <span class="stat-value">{m.metric}</span>
          <span class="stat-label">{m.label}</span>
        </div>
      ))}
    </div>
  </BaseSection>

  <!-- Process -->
  <BaseSection>
    <p class="eyebrow">Proceso</p>
    <h2 class="section-title">Cómo se implementó</h2>

    <div class="process-list">
      {process.map((step, i) => (
        <div class="process-item">
          <span class="process-num">{String(i + 1).padStart(2, "0")}</span>
          <div>
            <h3 class="process-title">{step.title}</h3>
            <p class="process-desc">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </BaseSection>

  <!-- Gallery -->
  <BaseSection>
    <p class="eyebrow">Capturas</p>
    <h2 class="section-title">El sistema en uso</h2>
    <GalleryComponent images={screenshots} />
  </BaseSection>

  <!-- Closing note -->
  <BaseSection className="text-center">
    <p class="lead">
      Proyecto desarrollado como parte del servicio social en la Universidad Politécnica de
      Pachuca, demostrando el potencial de las soluciones no-code para resolver problemas
      reales en entornos educativos.
    </p>
  </BaseSection>

  <style>
    .lead {
      font-family: 'Inter', sans-serif;
      font-size: 1.1rem;
      line-height: 1.7;
      color: #999;
      max-width: 42rem;
      margin: 0 auto 2rem;
    }

    .pill-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.6rem;
      margin-bottom: 1rem;
    }

    .eyebrow {
      font-family: 'Inter', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #444;
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      letter-spacing: -0.03em;
      color: #f0f0f0;
      margin-bottom: 2.5rem;
    }

    .compare-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .compare-label {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      color: #888;
      margin-bottom: 1rem;
    }
    .compare-label--accent { color: #e2e8f0; }

    .compare-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .compare-list li {
      font-family: 'Inter', sans-serif;
      font-size: 0.88rem;
      color: #888;
      padding-left: 1.1rem;
      position: relative;
      line-height: 1.5;
    }
    .compare-list li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: #444;
    }

    .arch-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
    .arch-label {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.95rem;
      color: #e2e8f0;
      margin-bottom: 0.6rem;
    }
    .arch-col p {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      line-height: 1.7;
      color: #777;
    }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .stat-item {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      padding-top: 1rem;
    }
    .stat-value {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.8rem;
      color: #f0f0f0;
    }
    .stat-label {
      font-family: 'Inter', sans-serif;
      font-size: 0.8rem;
      color: #888;
    }

    .process-list {
      display: flex;
      flex-direction: column;
    }
    .process-item {
      display: flex;
      gap: 1.5rem;
      padding: 1.5rem 0;
      border-top: 1px solid rgba(255, 255, 255, 0.07);
    }
    .process-item:last-child { border-bottom: 1px solid rgba(255, 255, 255, 0.07); }
    .process-num {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      color: #333;
      flex-shrink: 0;
      width: 2rem;
    }
    .process-title {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1.05rem;
      color: #f0f0f0;
      margin-bottom: 0.4rem;
    }
    .process-desc {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      color: #888;
      line-height: 1.6;
    }

    @media (max-width: 640px) {
      .compare-grid, .arch-grid, .feature-grid, .stat-grid { grid-template-columns: 1fr; }
    }
  </style>
</Layout>
