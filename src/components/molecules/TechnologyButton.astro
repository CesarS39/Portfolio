---
const { icon, label, isEmoji = false } = Astro.props;
---

<div class="tech-pill">
  {isEmoji
    ? <span class="tech-icon-emoji">{icon}</span>
    : <i class={`${icon} tech-icon-dev`} />
  }
  <span class="tech-label">{label}</span>
</div>

<style>
  .tech-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.85rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 2px;
    cursor: default;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .tech-pill:hover {
    border-color: rgba(226, 232, 240, 0.22);
    transform: translateY(-1px);
  }

  .tech-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    color: #c0c0c0;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .tech-icon-dev {
    font-size: 1rem;
    color: #e2e8f0;
    opacity: 0.7;
  }

  .tech-icon-emoji {
    font-size: 0.85rem;
    opacity: 0.7;
  }
</style>
