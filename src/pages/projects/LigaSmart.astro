---
import Layout from "../../layouts/Layout.astro";
import GalleryComponent from "../../components/organisms/GalleryComponent.astro";
import HeroTitle from "../../components/atoms/HeroTitle.astro";
import BaseSection from "../../components/atoms/BaseSection.astro";
import TechnologyButton from "../../components/molecules/TechnologyButton.astro";
import FeatureCard from "../../components/molecules/FeatureCard.astro";
import ProjectCTA from "../../components/molecules/ProjectCTA.astro";

const screenshots: string[] = [
  "/Portfolio/images/projects/ligasmart/Dashboard.webp",
  "/Portfolio/images/projects/ligasmart/login.webp",
  "/Portfolio/images/projects/ligasmart/Jugadores.webp",
  "/Portfolio/images/projects/ligasmart/Torneos.webp",
  "/Portfolio/images/projects/ligasmart/Asignar_torneo.webp",
  "/Portfolio/images/projects/ligasmart/Agendar_partidos.webp"
];

const techStack = [
  { name: ".NET Framework", icon: "devicon-dotnetcore-plain" },
  { name: "SQL Server", icon: "devicon-microsoftsqlserver-plain" },
  { name: "Azure Web App", icon: "devicon-azure-plain" },
  { name: "Bootstrap", icon: "devicon-bootstrap-plain" },
];

const modules = [
  {
    title: "Gestión de equipos",
    description: "Registro completo de equipos con plantillas, información detallada y estadísticas históricas de participación.",
  },
  {
    title: "Administración de jugadores",
    description: "Base de datos de jugadores con perfiles, estadísticas individuales y seguimiento de rendimiento por partido.",
  },
  {
    title: "Sistema de partidos",
    description: "Calendario, registro de resultados, árbitros asignados e incidencias del juego en tiempo real.",
  },
  {
    title: "Centro de estadísticas",
    description: "Reportes automáticos, gráficas dinámicas, análisis de tendencias y exportación de datos.",
  },
];

const before = [
  "Administración manual con hojas de cálculo",
  "Datos dispersos e inconsistentes",
  "Estadísticas básicas y poco detalladas",
  "Proceso lento para generar reportes",
  "Comunicación fragmentada entre organizadores",
];
const after = [
  "Sistema centralizado y automatizado",
  "Base de datos normalizada y consistente",
  "Estadísticas avanzadas en tiempo real",
  "Reportes automáticos personalizables",
  "Panel unificado para administradores",
];

const process = [
  { title: "Análisis y diseño", desc: "Modelado de entidades deportivas, casos de uso y arquitectura del sistema con Visual Studio." },
  { title: "Implementación core", desc: "Desarrollo de capas de presentación, lógica de negocio y acceso a datos con patrón MVC." },
  { title: "Testing y optimización", desc: "Pruebas de integración, optimización de consultas y ajustes de rendimiento." },
  { title: "Despliegue Azure", desc: "Configuración de Azure Web App, pruebas de producción e implementaciones finales." },
];
---

<Layout>
  <HeroTitle text="LIGASMART" size="text-[10vw]" />

  <!-- Summary -->
  <BaseSection className="text-center py-20">
    <p class="lead">
      Sistema integral de administración de torneos deportivos que digitaliza y optimiza
      la gestión completa desde equipos hasta estadísticas avanzadas.
    </p>
    <div class="pill-row">
      {techStack.map((t) => <TechnologyButton icon={t.icon} label={t.name} />)}
    </div>
    <p class="status-note">En despliegue — funcionalidades core completadas, en fase de testing final sobre Azure.</p>
    <ProjectCTA repo="https://github.com/Voxewl/GestorDeTorneos" />
  </BaseSection>

  <!-- Problem / Solution -->
  <BaseSection>
    <p class="eyebrow">El reto</p>
    <h2 class="section-title">Revolucionando la gestión deportiva</h2>

    <div class="compare-grid">
      <div class="compare-col">
        <h3 class="compare-label">Gestión tradicional</h3>
        <ul class="compare-list">
          {before.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="compare-col">
        <h3 class="compare-label compare-label--accent">Solución LigaSmart</h3>
        <ul class="compare-list">
          {after.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </BaseSection>

  <!-- Architecture -->
  <BaseSection>
    <p class="eyebrow">Arquitectura</p>
    <h2 class="section-title">Capas del sistema</h2>

    <div class="arch-grid">
      <div class="arch-col">
        <h4 class="arch-label">Presentación</h4>
        <p>Bootstrap + Razor Views · diseño responsivo · componentes reutilizables · validación client-side</p>
      </div>
      <div class="arch-col">
        <h4 class="arch-label">Lógica de negocio</h4>
        <p>C# Business Logic Layer · reglas de torneos · cálculos estadísticos · validaciones complejas</p>
      </div>
      <div class="arch-col">
        <h4 class="arch-label">Acceso a datos</h4>
        <p>DAO Pattern + SQL Server · procedimientos almacenados · vistas optimizadas · logs de cambios y transacciones ACID</p>
      </div>
    </div>
  </BaseSection>

  <!-- Modules -->
  <BaseSection>
    <p class="eyebrow">Módulos</p>
    <h2 class="section-title">El sistema en detalle</h2>

    <div class="feature-grid">
      {modules.map((m, i) => (
        <FeatureCard index={i + 1} title={m.title} description={m.description} />
      ))}
    </div>
  </BaseSection>

  <!-- Process -->
  <BaseSection>
    <p class="eyebrow">Proceso</p>
    <h2 class="section-title">Cómo se construyó</h2>

    <div class="process-list">
      {process.map((step, i) => (
        <div class="process-item">
          <span class="process-num">{String(i + 1).padStart(2, "0")}</span>
          <div>
            <h3 class="process-title">{step.title}</h3>
            <p class="process-desc">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </BaseSection>

  <!-- Gallery -->
  <BaseSection>
    <p class="eyebrow">Capturas</p>
    <h2 class="section-title">Interfaces del sistema</h2>
    <GalleryComponent images={screenshots} />
  </BaseSection>

  <style>
    .lead {
      font-family: 'Inter', sans-serif;
      font-size: 1.1rem;
      line-height: 1.7;
      color: #999;
      max-width: 42rem;
      margin: 0 auto 2rem;
    }

    .pill-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.6rem;
      margin-bottom: 1.5rem;
    }

    .status-note {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      color: #777;
      max-width: 32rem;
      margin: 0 auto 2rem;
    }

    .eyebrow {
      font-family: 'Inter', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #444;
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      letter-spacing: -0.03em;
      color: #f0f0f0;
      margin-bottom: 2.5rem;
    }

    .compare-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .compare-label {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      color: #888;
      margin-bottom: 1rem;
    }
    .compare-label--accent { color: #e2e8f0; }

    .compare-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .compare-list li {
      font-family: 'Inter', sans-serif;
      font-size: 0.88rem;
      color: #888;
      padding-left: 1.1rem;
      position: relative;
      line-height: 1.5;
    }
    .compare-list li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: #444;
    }

    .arch-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
    .arch-label {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.95rem;
      color: #e2e8f0;
      margin-bottom: 0.6rem;
    }
    .arch-col p {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      line-height: 1.7;
      color: #777;
    }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .process-list {
      display: flex;
      flex-direction: column;
    }
    .process-item {
      display: flex;
      gap: 1.5rem;
      padding: 1.5rem 0;
      border-top: 1px solid rgba(255, 255, 255, 0.07);
    }
    .process-item:last-child { border-bottom: 1px solid rgba(255, 255, 255, 0.07); }
    .process-num {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      color: #333;
      flex-shrink: 0;
      width: 2rem;
    }
    .process-title {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1.05rem;
      color: #f0f0f0;
      margin-bottom: 0.4rem;
    }
    .process-desc {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      color: #888;
      line-height: 1.6;
    }

    @media (max-width: 640px) {
      .compare-grid, .arch-grid, .feature-grid { grid-template-columns: 1fr; }
    }
  </style>
</Layout>
