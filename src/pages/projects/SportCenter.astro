---
import Layout from "../../layouts/Layout.astro";
import GalleryComponent from "../../components/organisms/GalleryComponent.astro";
import HeroTitle from "../../components/atoms/HeroTitle.astro";
import BaseSection from "../../components/atoms/BaseSection.astro";
import TechnologyButton from "../../components/molecules/TechnologyButton.astro";
import FeatureCard from "../../components/molecules/FeatureCard.astro";
import ProjectCTA from "../../components/molecules/ProjectCTA.astro";

const screenshots: string[] = [
  "/Portfolio/images/projects/sportCenter/menu1.webp",
  "/Portfolio/images/projects/sportCenter/menu2.webp",
  "/Portfolio/images/projects/sportCenter/menu3.webp",
  "/Portfolio/images/projects/sportCenter/login.webp",
  "/Portfolio/images/projects/sportCenter/userDashboard.webp",
  "/Portfolio/images/projects/sportCenter/reservar1.webp",
  "/Portfolio/images/projects/sportCenter/reservar2.webp",
  "/Portfolio/images/projects/sportCenter/reservar3.webp",
  "/Portfolio/images/projects/sportCenter/dashboardAdmin.webp",
  "/Portfolio/images/projects/sportCenter/adminCanchas.webp",
  "/Portfolio/images/projects/sportCenter/adminReservas.webp",
  "/Portfolio/images/projects/sportCenter/adminUsuarios.webp",
];

const techStack = [
  { name: "Next.js 14" },
  { name: "Supabase" },
  { name: "TypeScript", icon: "devicon-typescript-plain" },
  { name: "Tailwind CSS", icon: "devicon-tailwindcss-original" },
];

const databaseSchema = [
  { table: "sport_types", description: "Tipos de deportes disponibles", fields: ["id", "name", "description", "max_people"] },
  { table: "courts", description: "Canchas deportivas del club", fields: ["id", "name", "sport_type_id", "price_per_hour", "active"] },
  { table: "user_profiles", description: "Perfiles de usuarios", fields: ["user_id", "name", "phone", "role"] },
  { table: "reservations", description: "Sistema de reservas", fields: ["user_id", "court_id", "date", "start_time", "status"] },
];

const features = [
  {
    title: "Sistema de reservas inteligente",
    description: "Reserva de canchas en tiempo real con validación automática de disponibilidad, calendario interactivo y confirmación automática.",
  },
  {
    title: "Gestión premium de instalaciones",
    description: "Administración de canchas de tenis, pádel y fútbol 5 con precios diferenciados por deporte y control de disponibilidad.",
  },
  {
    title: "Autenticación y roles",
    description: "Sistema seguro con Supabase Auth que maneja usuarios, administradores, perfiles y middleware de protección.",
  },
  {
    title: "Dashboard administrativo",
    description: "Panel para gestión de canchas, usuarios, reservas y estadísticas del club en tiempo real.",
  },
];

const impactMetrics = [
  { metric: "100%", label: "Responsivo en todos los dispositivos" },
  { metric: "3", label: "Deportes: tenis, pádel y fútbol 5" },
  { metric: "24/7", label: "Sistema disponible" },
  { metric: "Real-time", label: "Sincronización de reservas" },
];

const process = [
  { title: "Análisis y diseño", desc: "Modelado de entidades deportivas, UX/UI y arquitectura del sistema con Next.js y Supabase." },
  { title: "Configuración backend", desc: "Diseño de esquema PostgreSQL, configuración de Supabase, Row Level Security y autenticación." },
  { title: "Desarrollo frontend", desc: "Implementación con Next.js 14, TypeScript y Tailwind CSS; componentes reutilizables y páginas responsivas." },
  { title: "Testing y despliegue", desc: "Pruebas de funcionalidad, validación de seguridad, optimización de performance y despliegue en Vercel." },
];
---

<Layout>
  <HeroTitle text="SPORTCENTER" size="text-[10vw]" />

  <!-- Summary -->
  <BaseSection className="text-center py-20">
    <p class="lead">
      Plataforma de gestión para club deportivo premium con sistema de reservas online,
      autenticación segura y dashboard administrativo desarrollado con Next.js y Supabase.
    </p>
    <div class="pill-row">
      {techStack.map((t) => <TechnologyButton icon={t.icon} label={t.name} />)}
    </div>
    <ProjectCTA demo="https://sport-center-eight.vercel.app" repo="https://github.com/CesarS39/SportCenter" />
  </BaseSection>

  <!-- Problem / Solution -->
  <BaseSection>
    <p class="eyebrow">El reto</p>
    <h2 class="section-title">Modernizando la gestión deportiva</h2>

    <div class="compare-grid">
      <div class="compare-col">
        <h3 class="compare-label">Desafíos identificados</h3>
        <ul class="compare-list">
          <li>Gestión manual de reservas propensa a errores</li>
          <li>Falta de sistema digital para clubs deportivos</li>
          <li>Ausencia de control de disponibilidad en tiempo real</li>
          <li>Necesidad de interfaz moderna y responsive</li>
        </ul>
      </div>
      <div class="compare-col">
        <h3 class="compare-label compare-label--accent">Solución SportCenter</h3>
        <ul class="compare-list">
          <li>Sistema automatizado de reservas online</li>
          <li>Plataforma escalable con tecnologías modernas</li>
          <li>Validación en tiempo real de disponibilidad</li>
          <li>Experiencia de usuario premium y responsiva</li>
        </ul>
      </div>
    </div>
  </BaseSection>

  <!-- Architecture -->
  <BaseSection>
    <p class="eyebrow">Arquitectura</p>
    <h2 class="section-title">Frontend y backend</h2>

    <div class="arch-grid arch-grid--2">
      <div class="arch-col">
        <h4 class="arch-label">Frontend moderno</h4>
        <p>Next.js 14 con App Router · React Server Components para mejor SEO y performance · TypeScript con tipado estático completo</p>
      </div>
      <div class="arch-col">
        <h4 class="arch-label">Backend escalable</h4>
        <p>Supabase como Backend-as-a-Service · PostgreSQL con Row Level Security · autenticación JWT con manejo automático de sesiones</p>
      </div>
    </div>

    <div class="db-grid">
      {databaseSchema.map((t) => (
        <div class="db-card">
          <h4 class="db-name">{t.table}</h4>
          <p class="db-desc">{t.description}</p>
          <div class="db-fields">
            {t.fields.map((f) => <span class="db-field">{f}</span>)}
          </div>
        </div>
      ))}
    </div>
  </BaseSection>

  <!-- Features -->
  <BaseSection>
    <p class="eyebrow">Características</p>
    <h2 class="section-title">Funcionalidades principales</h2>

    <div class="feature-grid">
      {features.map((f, i) => (
        <FeatureCard index={i + 1} title={f.title} description={f.description} />
      ))}
    </div>
  </BaseSection>

  <!-- Impact -->
  <BaseSection>
    <p class="eyebrow">Impacto</p>
    <h2 class="section-title">Métricas del sistema</h2>

    <div class="stat-grid">
      {impactMetrics.map((m) => (
        <div class="stat-item">
          <span class="stat-value">{m.metric}</span>
          <span class="stat-label">{m.label}</span>
        </div>
      ))}
    </div>
  </BaseSection>

  <!-- Code example -->
  <BaseSection>
    <p class="eyebrow">Implementación</p>
    <h2 class="section-title">Validación de reservas</h2>

    <div class="code-block">
      <div class="code-header">
        <span>TypeScript + Supabase</span>
        <span>Sistema de reservas</span>
      </div>
      <pre><code>{`// Validación de reserva con Supabase
const handleReservation = async () => {
  const { data: existingReservations, error } = await supabase
    .from('reservations')
    .select('*')
    .eq('court_id', selectedCourt.id)
    .eq('date', selectedDate.toISOString().split('T')[0])
    .eq('status', 'ACTIVE')

  // Validar conflictos de horario
  const hasConflict = existingReservations?.some(reservation =>
    timeOverlap(reservation.start_time, reservation.end_time,
                selectedTime, endTime))

  if (!hasConflict) {
    const { error } = await supabase
      .from('reservations')
      .insert({
        user_id: user.id,
        court_id: selectedCourt.id,
        date: selectedDate,
        start_time: selectedTime,
        status: 'ACTIVE'
      })
  }
}`}</code></pre>
    </div>
  </BaseSection>

  <!-- Process -->
  <BaseSection>
    <p class="eyebrow">Proceso</p>
    <h2 class="section-title">Cómo se construyó</h2>

    <div class="process-list">
      {process.map((step, i) => (
        <div class="process-item">
          <span class="process-num">{String(i + 1).padStart(2, "0")}</span>
          <div>
            <h3 class="process-title">{step.title}</h3>
            <p class="process-desc">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </BaseSection>

  <!-- Gallery -->
  <BaseSection>
    <p class="eyebrow">Capturas</p>
    <h2 class="section-title">El sistema en uso</h2>
    <GalleryComponent images={screenshots} />
  </BaseSection>

  <!-- Future roadmap -->
  <BaseSection>
    <p class="eyebrow">Roadmap</p>
    <h2 class="section-title">Futuras mejoras y escalabilidad</h2>

    <div class="compare-grid">
      <div class="compare-col">
        <h3 class="compare-label">Mejoras técnicas</h3>
        <ul class="compare-list">
          <li>Sistema de pagos online con Stripe</li>
          <li>Aplicación móvil nativa con React Native</li>
          <li>Notificaciones push y recordatorios</li>
          <li>Analytics avanzados y reportes</li>
        </ul>
      </div>
      <div class="compare-col">
        <h3 class="compare-label compare-label--accent">Expansión del negocio</h3>
        <ul class="compare-list">
          <li>Sistema de membresías y suscripciones</li>
          <li>Integración con múltiples clubs deportivos</li>
          <li>Torneos y competencias online</li>
          <li>API pública para integraciones</li>
        </ul>
      </div>
    </div>

    <p class="status-note">Desplegado en Vercel · Next.js 14 · Supabase · TypeScript · Tailwind + shadcn/ui</p>
  </BaseSection>

  <style>
    .lead {
      font-family: 'Inter', sans-serif;
      font-size: 1.1rem;
      line-height: 1.7;
      color: #999;
      max-width: 42rem;
      margin: 0 auto 2rem;
    }

    .pill-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.6rem;
      margin-bottom: 2.5rem;
    }

    .status-note {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      color: #777;
      text-align: center;
      margin-top: 2.5rem;
    }

    .eyebrow {
      font-family: 'Inter', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #444;
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      letter-spacing: -0.03em;
      color: #f0f0f0;
      margin-bottom: 2.5rem;
    }

    .compare-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .compare-label {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      color: #888;
      margin-bottom: 1rem;
    }
    .compare-label--accent { color: #e2e8f0; }

    .compare-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .compare-list li {
      font-family: 'Inter', sans-serif;
      font-size: 0.88rem;
      color: #888;
      padding-left: 1.1rem;
      position: relative;
      line-height: 1.5;
    }
    .compare-list li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: #444;
    }

    .arch-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
    .arch-grid--2 {
      grid-template-columns: repeat(2, 1fr);
      margin-bottom: 2.5rem;
    }
    .arch-label {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.95rem;
      color: #e2e8f0;
      margin-bottom: 0.6rem;
    }
    .arch-col p {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      line-height: 1.7;
      color: #777;
    }

    .db-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
    .db-card {
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.02);
      padding: 1.25rem;
    }
    .db-name {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.95rem;
      color: #e2e8f0;
      margin-bottom: 0.4rem;
    }
    .db-desc {
      font-family: 'Inter', sans-serif;
      font-size: 0.8rem;
      color: #888;
      margin-bottom: 0.75rem;
    }
    .db-fields {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .db-field {
      font-family: 'SF Mono', 'Consolas', monospace;
      font-size: 0.72rem;
      color: #777;
      background: rgba(255, 255, 255, 0.03);
      padding: 0.2rem 0.4rem;
      width: fit-content;
    }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
    .stat-item {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      padding-top: 1rem;
    }
    .stat-value {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.8rem;
      color: #f0f0f0;
    }
    .stat-label {
      font-family: 'Inter', sans-serif;
      font-size: 0.8rem;
      color: #888;
    }

    .code-block {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.08);
      padding: 1.5rem;
    }
    .code-header {
      display: flex;
      justify-content: space-between;
      font-family: 'Inter', sans-serif;
      font-size: 0.75rem;
      color: #666;
      margin-bottom: 1rem;
    }
    .code-block pre {
      font-family: 'SF Mono', 'Consolas', monospace;
      font-size: 0.8rem;
      line-height: 1.6;
      color: #b0b0b0;
      overflow-x: auto;
    }

    .process-list {
      display: flex;
      flex-direction: column;
    }
    .process-item {
      display: flex;
      gap: 1.5rem;
      padding: 1.5rem 0;
      border-top: 1px solid rgba(255, 255, 255, 0.07);
    }
    .process-item:last-child { border-bottom: 1px solid rgba(255, 255, 255, 0.07); }
    .process-num {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      color: #333;
      flex-shrink: 0;
      width: 2rem;
    }
    .process-title {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1.05rem;
      color: #f0f0f0;
      margin-bottom: 0.4rem;
    }
    .process-desc {
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      color: #888;
      line-height: 1.6;
    }

    @media (max-width: 640px) {
      .compare-grid, .arch-grid, .feature-grid, .db-grid { grid-template-columns: 1fr; }
      .stat-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</Layout>
